# Build stage
FROM --platform=$BUILDPLATFORM golang:1.26.4-alpine AS builder

ARG TARGETOS
ARG TARGETARCH

WORKDIR /workspace

# Set Go proxy with multiple fallbacks for reliability
ENV GOPROXY=https://goproxy.cn,https://goproxy.io,https://proxy.golang.org,direct

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY pkg/sidecar/ pkg/sidecar/
COPY pkg/execagent/ pkg/execagent/
COPY pkg/interfaces/ pkg/interfaces/
COPY pkg/grpcauth/ pkg/grpcauth/
COPY pkg/pb/ pkg/pb/
COPY pkg/tracing/ pkg/tracing/
COPY cmd/sidecar/ cmd/sidecar/

# Build
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} GOMAXPROCS=8 go build -p 8 -a -o sidecar cmd/sidecar/main.go

# Final stage
FROM gcr.io/distroless/static:nonroot

COPY --from=builder /workspace/sidecar /sidecar

EXPOSE 8080 9090

ENTRYPOINT ["/sidecar"]
CMD ["--workspace=/workspace", "--http-port=8080", "--grpc-port=9090"]
