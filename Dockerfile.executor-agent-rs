FROM rust:alpine AS builder
RUN apk add --no-cache musl-dev protobuf-dev
WORKDIR /build
COPY proto/executor.proto proto/
COPY rust/executor-agent/ rust/executor-agent/
WORKDIR /build/rust/executor-agent
RUN rm -f .cargo/config.toml && cargo build --release

FROM busybox:latest
COPY --from=builder /build/rust/executor-agent/target/release/executor-agent /executor-agent
ENTRYPOINT ["/executor-agent"]
