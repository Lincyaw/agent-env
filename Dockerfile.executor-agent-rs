FROM rust:1.87-alpine AS builder
RUN apk add --no-cache musl-dev
WORKDIR /build
COPY rust/executor-agent/ .
# Alpine default target is already x86_64-unknown-linux-musl.
# Remove .cargo/config.toml which specifies a cross-linker not available here.
RUN rm -f .cargo/config.toml && cargo build --release

FROM busybox:latest
COPY --from=builder /build/target/release/executor-agent /executor-agent
ENTRYPOINT ["/executor-agent"]
